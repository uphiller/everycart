# -----------------------------------------------------------------------------
# 예시 변수 — 실 값은 저장소 밖(server 전용 디렉터리) 에 두거나,
# 필요할 때 여러 번 -var-file 로 합치면 됩니다.
#
# 적용 예 (배포 서버에서 infra/ecs 로 이동한 뒤):
#   terraform init
#   terraform apply -var-file=terraform.tfvars -var-file=/secure/everycart-keycloak.secrets.tfvars
#
# Git 에 올리지 말 파일: infra/ecs/terraform.tfvars, infra/ecs/*.secrets.tfvars 등
# (루트 .gitignore 참고)
# -----------------------------------------------------------------------------
aws_region      = "us-east-1"
project_name    = "everycart"
container_image = "uphiller/everycart:front"
container_port  = 80
desired_count   = 1

# -----------------------------------------------------------------------------
# ALB HTTPS (ACM) — DNS 가 Cloudflare 인 경우 (route53 변수 비움)
# -----------------------------------------------------------------------------
# enable_https = true
# route53_zone_id = ""   # Cloudflare 사용 시 비워 둠
# acm_certificate_arn = ""   # 이미 발급·검증된 ACM ARN 이 있으면 지정 가능
#
# 1) terraform apply -target=aws_acm_certificate.main[0]
# 2) terraform output cloudflare_dns_setup → acm_validation CNAME 을 Cloudflare 에 추가
#    - Proxy: DNS only (회색 구름) — ACM 검증용
# 3) ACM 콘솔에서 인증서 상태 ISSUED 확인
# 4) Cloudflare 에 origin CNAME 추가 (output 의 origin, Proxy: Proxied 권장)
#    - everycart / auth → alb_dns_name (terraform output alb_dns_name)
# 5) Cloudflare SSL/TLS → Full (strict)  (방문자↔CF 는 CF 인증서, CF↔ALB 는 ACM)
# 6) terraform apply  (HTTPS 리스너·리다이렉트 완료)
#
# Route 53 을 쓰는 경우에만:
# route53_zone_id = "Z..."
# create_route53_alias_records = true

# -----------------------------------------------------------------------------
# Keycloak — 공개에 가까운 옵션
# -----------------------------------------------------------------------------
# keycloak_host_header = "auth.example.com"   # ALB host 조건 + KC_HOSTNAME / KC_HOSTNAME_ADMIN → https://auth.example.com
# keycloak_http_enabled = true                 # ALB→컨테이너 HTTP 면 true

# 시작 모드 / DB (variables.tf 기본값: Supabase Postgres + start)
# keycloak_container_command = ["start"]
# keycloak_db_url      = "jdbc:postgresql://db.<project-ref>.supabase.co:5432/keycloak?sslmode=require"
# keycloak_db_username = "postgres"
# keycloak_db_kind     = "postgres"
#
# 내장 H2 로 되돌리려면:
#   keycloak_db_url = ""
#   keycloak_container_command = ["start-dev"]

# -----------------------------------------------------------------------------
# 비밀 — 서버 로컬 tfvars 또는 TF_VAR_keycloak_* 등으로만 설정 (커밋 금지)
# -----------------------------------------------------------------------------
# keycloak_admin_username  = "admin"
# keycloak_admin_password = "REPLACE_ME"

# 비밀을 Terraform 변수 대신 ECS 가 SSM/Secrets Manager 에서 주입하게 하려면
# ARN 을 채우고, 아래에 해당 변수는 두지 마세요(SECRETS 쪽 참고).
# keycloak_admin_password_secret_arn = "arn:aws:ssm:REGION:ACCOUNT:parameter/keycloak/admin-password"
# keycloak_db_password_secret_arn    = "arn:aws:secretsmanager:REGION:ACCOUNT:secret:keycloak/db-xxx"

# DB 비밀번호 — keycloak.secrets.tfvars (gitignore) 에만:
#   keycloak_db_password = "REPLACE_ME"
# 또는 keycloak_db_password_secret_arn
