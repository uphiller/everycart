# -----------------------------------------------------------------------------
# 비밀 — 서버 로컬 tfvars 또는 TF_VAR_keycloak_* 등으로만 설정 (커밋 금지)
# -----------------------------------------------------------------------------
# keycloak_admin_username  = "admin"
# keycloak_admin_password = "REPLACE_ME"

# 비밀을 Terraform 변수 대신 ECS 가 SSM/Secrets Manager 에서 주입하게 하려면
# ARN 을 채우고, 아래에 해당 변수는 두지 마세요(SECRETS 쪽 참고).
# keycloak_admin_password_secret_arn = "arn:aws:ssm:REGION:ACCOUNT:parameter/keycloak/admin-password"
# keycloak_db_password_secret_arn    = "arn:aws:secretsmanager:REGION:ACCOUNT:secret:keycloak/db-xxx"

# -----------------------------------------------------------------------------
# 외부 Postgres — keycloak_container_command 에 start/start --optimized 필요
 keycloak_db_url       = "jdbc:postgresql://db.jsadkloxgwvzucualbje.supabase.co:5432/keycloak"
 keycloak_db_username  = "postgres"
