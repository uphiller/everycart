# Copy to keycloak.secrets.tfvars (gitignored) and fill in values:
#   cp keycloak.secret.example keycloak.secrets.tfvars
#
# Apply:
#   terraform apply -var-file=keycloak.secrets.tfvars
# -----------------------------------------------------------------------------
# keycloak_admin_username  = "admin"
# keycloak_admin_password  = "REPLACE_ME"

# keycloak_admin_password_secret_arn = "arn:aws:ssm:REGION:ACCOUNT:parameter/keycloak/admin-password"
# keycloak_db_password_secret_arn    = "arn:aws:secretsmanager:REGION:ACCOUNT:secret:keycloak/db-xxx"

# DB password only — URL/username/kind/command defaults are in variables.tf (Supabase).
# keycloak_db_password = "REPLACE_ME"
