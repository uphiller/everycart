# Copy to backend.secrets.tfvars (gitignored) only when backend-specific secrets differ from Keycloak.
#   cp backend.secret.example backend.secrets.tfvars
#
# Apply (with keycloak secrets if already used):
#   terraform apply -var-file=terraform.tfvars -var-file=keycloak.secrets.tfvars
#
# When backend uses the same Supabase DB password and Keycloak admin password as Keycloak,
# leave backend_db_password_secret_arn and backend_keycloak_admin_password_secret_arn empty —
# Terraform reuses keycloak_* secret ARNs automatically.
# -----------------------------------------------------------------------------
# backend_db_password = "REPLACE_ME"
# backend_db_password_secret_arn = "arn:aws:ssm:REGION:ACCOUNT:parameter/backend/db-password"
# backend_keycloak_admin_password_secret_arn = "arn:aws:ssm:REGION:ACCOUNT:parameter/keycloak/admin-password"
